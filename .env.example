DATABASE_URL="file:./dev.db"

# JWT — Must be at least 32 characters. Required in production.
JWT_SECRET="code-judge-dev-secret-key-change-in-production-must-be-32-chars"
JWT_EXPIRES_IN="3600"

# Server
PORT=4100
HOST_PORT=4100

# CORS
CORS_ORIGINS="http://localhost:3000"

# Internal API key for judge worker communication
INTERNAL_API_KEY="internal-judge-worker-key-change-in-production"

# Judge queue
# Production uses Redis/BullMQ. Tests and local single-process runs may use inline.
JUDGE_QUEUE_DRIVER="inline"
REDIS_URL="redis://localhost:6379"
JUDGE_CONCURRENCY=2
JUDGE_JOB_ATTEMPTS=3
JUDGE_STUCK_AFTER_SECONDS=300
JUDGE_SAMPLE_RESULT_TIMEOUT_MS=15000

# Domain name for Caddy SSL proxy (e.g. "your-domain.com" or "localhost" for local testing)
DOMAIN_NAME="localhost"
