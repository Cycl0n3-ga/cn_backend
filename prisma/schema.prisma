// Online Code Judge — Prisma Schema
// Database: SQLite default. PostgreSQL requires a separate provider/migration path.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── User ────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String?  @unique
  passwordHash String
  role         String   @default("CANDIDATE") // "ADMIN" | "EXAMINER" | "QUESTIONER" | "CANDIDATE"
  solvedCount  Int      @default(0)
  rating       Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions          Submission[]
  assignments          Assignment[]
  problemsCreated      Problem[]             @relation("ProblemCreator")
  interviewsCreated    Interview[] // 作為面試官建立的面試
  interviewCandidates  InterviewCandidate[] // 作為被面試者的記錄
  interviewAssignments InterviewAssignment[] // 作為考生被指派的題目

  @@index([role, rating, solvedCount])
  @@map("users")
}

// ─── Problem ─────────────────────────────────────────────────
model Problem {
  id             Int      @id @default(autoincrement())
  title          String
  description    String
  difficulty     String   @default("EASY") // "EASY" | "MEDIUM" | "HARD"
  timeLimitMs    Int      @default(1000)
  memoryLimitMb  Int      @default(256)
  functionName   String? // [NEW] 預期使用者實作的 function 名稱
  creatorId      String?
  acceptanceRate Float    @default(0)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  creator              User?                 @relation("ProblemCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  testCases            TestCase[]
  submissions          Submission[]
  assignments          Assignment[]
  interviewAssignments InterviewAssignment[]

  @@index([creatorId])
  @@map("problems")
}

// ─── TestCase ────────────────────────────────────────────────
model TestCase {
  id        Int     @id @default(autoincrement())
  problemId Int
  input     String
  output    String
  isHidden  Boolean @default(true)

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@map("test_cases")
}

// ─── Submission ──────────────────────────────────────────────
model Submission {
  id              String   @id @default(uuid())
  userId          String
  problemId       Int
  language        String
  sourceCode      String
  status          String   @default("PENDING") // PENDING | COMPILING | RUNNING | ACCEPTED | WRONG_ANSWER | TLE | MLE | RUNTIME_ERROR | COMPILE_ERROR
  score           Int      @default(0)
  userOutput      String? // [NEW] 使用者程式碼產生的答案
  compileMessage  String   @default("")
  executionTimeMs Int?
  memoryUsageKb   Int?
  judgeJobId      String?
  queuedAt        DateTime?
  startedAt       DateTime?
  finishedAt      DateTime?
  attempts        Int      @default(0)
  lastError       String?
  createdAt       DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@index([userId])
  @@index([userId, problemId, status])
  @@index([problemId, status])
  @@index([status, createdAt])
  @@index([judgeJobId])
  @@map("submissions")
}

// ─── Assignment (題目指派) ────────────────────────────────────
model Assignment {
  id        Int      @id @default(autoincrement())
  problemId Int
  userId    String
  createdAt DateTime @default(now())

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([problemId, userId])
  @@map("assignments")
}

// ─── Interview (面試) ──────────────────────────────────────────
model Interview {
  id            Int      @id @default(autoincrement())
  jobRole       String
  examinerEmpId String // 參考 User.id
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  examiner             User                  @relation(fields: [examinerEmpId], references: [id])
  candidates           InterviewCandidate[]
  interviewAssignments InterviewAssignment[]

  @@map("interviews")
}

// ─── InterviewCandidate (面試者) ───────────────────────────────
model InterviewCandidate {
  id        Int      @id @default(autoincrement())
  jobId     Int // 對應 Interview.id
  userId    String // 對應 User.id
  startTime Int? // 測驗開始時間（Unix timestamp seconds）
  endTime   Int? // 測驗結束時間（Unix timestamp seconds）
  createdAt DateTime @default(now())

  interview Interview @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([userId])
  @@map("interview_candidates")
}

// ─── InterviewAssignment (面試題目指派) ────────────────────────
// 由面試官將特定題目指派給面試中的考生（code-judge 系統）
model InterviewAssignment {
  id        Int      @id @default(autoincrement())
  jobId     Int // 對應 Interview.id
  userId    String // 對應 User.id（考生）
  problemId Int // 對應 Problem.id
  createdAt DateTime @default(now())

  interview Interview @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId, problemId])
  @@index([userId])
  @@index([jobId])
  @@map("interview_assignments")
}

// ─── StressTestReport (壓力測試報告) ────────────────────────────
model StressTestReport {
  id             String   @id @default(uuid())
  testName       String // 測試名稱，如 "Spike Test — Health (200 connections)"
  endpoint       String // 被測試的端點，如 "/api/v1/health"
  method         String   @default("GET") // HTTP 方法
  connections    Int // 並發連接數
  duration       Int // 持續時間（秒）
  totalRequests  Int // 總請求數
  successfulReqs Int // 成功的請求數 (2xx)
  failedReqs     Int // 失敗的請求數
  errors         Int // 連接錯誤數
  timeouts       Int // 超時數
  avgLatencyMs   Float // 平均延遲（毫秒）
  p50LatencyMs   Float // 50 百分位數延遲
  p99LatencyMs   Float // 99 百分位數延遲
  maxLatencyMs   Float // 最大延遲
  avgThroughput  Float // 平均吞吐量（req/sec）
  statusCodes    String // JSON 字符串存儲狀態碼分佈 { "2xx": 0, "4xx": 0, "5xx": 1712 }
  assessment     String // 評估結果，如 "PASSED" | "WARNING" | "FAILED"
  assessmentMsg  String // 詳細的評估信息
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([endpoint])
  @@map("stress_test_reports")
}

// ─── HealthMetric (系統健康指標) ─────────────────────────────
model HealthMetric {
  id                String   @id @default(uuid())
  timestamp         DateTime @default(now())
  cpuUsagePercent   Float? // CPU 使用率百分比
  memoryUsageMb     Float? // 內存使用量（MB）
  activeConnections Int? // 活躍連接數
  queuedRequests    Int? // 排隊中的請求數
  responseTime50    Float? // 50 百分位數響應時間
  responseTime99    Float? // 99 百分位數響應時間
  errorRate         Float? // 錯誤率百分比
  description       String? // 可選的描述

  @@index([timestamp])
  @@map("health_metrics")
}
