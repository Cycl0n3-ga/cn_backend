// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int                  @id @default(autoincrement())
  passwordHash        String
  isAdmin             Boolean              @default(false)
  isCandidate         Boolean              @default(false)
  isExaminer          Boolean              @default(false)
  isQuestioner        Boolean              @default(false)
  empId               String?              @unique
  name                String               @default("")
  email               String               @unique
  authoredQuestions   Question[]
  assignedCandidates  InterviewCandidate[]
  assignments         Assignment[]
  submissions         Submission[]
  examinerInterviews  Interview[]          @relation("InterviewExaminer")

  @@map("users")
}

model Interview {
  id             Int                  @id @default(autoincrement())
  jobRole        String
  examinerEmpId  String
  examiner       User                 @relation("InterviewExaminer", fields: [examinerEmpId], references: [empId])
  candidates     InterviewCandidate[]
  assignments    Assignment[]

  @@map("interviews")
}

model InterviewCandidate {
  id        Int       @id @default(autoincrement())
  jobId     Int
  userId    Int
  interview Interview @relation(fields: [jobId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@map("interviewCandidates")
}

model Question {
  id            Int          @id @default(autoincrement())
  title         String
  prompt        String
  example       String
  exampleAns    String
  testcase      String
  testcaseAns   String
  authorUserId  Int
  author        User         @relation(fields: [authorUserId], references: [id])
  assignments   Assignment[]
  submissions   Submission[]

  @@map("questions")
}

model Assignment {
  id          Int          @id @default(autoincrement())
  jobId       Int
  userId      Int
  questionId  Int
  interview   Interview    @relation(fields: [jobId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  question    Question     @relation(fields: [questionId], references: [id])
  submissions Submission[]

  @@map("assignments")
}

model Submission {
  id              Int              @id @default(autoincrement())
  assignmentId    Int
  userId          Int
  questionId      Int
  language        String
  code            String
  status          SubmissionStatus @default(PENDING)
  stdout          String           @default("")
  stderr          String           @default("")
  expectedOutput  String           @default("")
  score           Int              @default(0)
  executionTimeMs Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignment      Assignment       @relation(fields: [assignmentId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  question        Question         @relation(fields: [questionId], references: [id])

  @@map("submissions")
}

enum SubmissionStatus {
  PENDING
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  INTERNAL_ERROR
}
